generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model FacebookGroupScan {
  id                  String              @id @default(uuid())
  scanDate            DateTime            @db.Date
  scanTimestamp       DateTime
  scrapedAt           DateTime            @default(now())
  totalGroupsScanned  Int
  totalPostsScanned   Int
  anomaliesDetected   Int
  groupsSummary       Json
  anomalies           FacebookAnomaly[]

  @@map("facebook_group_scans")
}

model FacebookAnomaly {
  id               String   @id @default(uuid())
  postId           String   @unique
  groupId          String
  groupName        String
  message          String?  @db.Text
  imageUrl         String?  @db.Text
  attachmentUrl    String?  @db.Text
  createdTime      DateTime
  authorId         String?
  authorName       String?
  severityLevel    Int
  category         String
  summary          String   @db.Text
  detectedKeywords String[]
  location         String?
  scrapedAt        DateTime @default(now())

  scan   FacebookGroupScan? @relation(fields: [scanId], references: [id])
  scanId String?

  @@index([groupId])
  @@index([category])
  @@index([severityLevel])
  @@index([scrapedAt])
  @@map("facebook_anomalies")
}
